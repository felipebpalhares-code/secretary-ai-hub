# Multi-stage build pro Next.js · imagem final ~150MB
FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev || npm install --omit=dev

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
# Variáveis públicas precisam estar disponíveis no build
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_WS_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL
# Feature flags — vide docs/PENDENCIAS.md
ARG NEXT_PUBLIC_FEATURE_AGENDA=false
ARG NEXT_PUBLIC_FEATURE_BATER_PAPO=false
ARG NEXT_PUBLIC_FEATURE_DOCUMENTOS=false
ARG NEXT_PUBLIC_FEATURE_FINANCAS=false
ARG NEXT_PUBLIC_FEATURE_BANCOS_BOLETOS=false
ARG NEXT_PUBLIC_FEATURE_BANCOS_CARTOES=false
ARG NEXT_PUBLIC_FEATURE_BANCOS_PIX=false
ARG NEXT_PUBLIC_FEATURE_BANCOS_TRIBUTOS=false
ARG NEXT_PUBLIC_FEATURE_BUSCA_EMPRESAS_POR_CPF=false
ENV NEXT_PUBLIC_FEATURE_AGENDA=$NEXT_PUBLIC_FEATURE_AGENDA
ENV NEXT_PUBLIC_FEATURE_BATER_PAPO=$NEXT_PUBLIC_FEATURE_BATER_PAPO
ENV NEXT_PUBLIC_FEATURE_DOCUMENTOS=$NEXT_PUBLIC_FEATURE_DOCUMENTOS
ENV NEXT_PUBLIC_FEATURE_FINANCAS=$NEXT_PUBLIC_FEATURE_FINANCAS
ENV NEXT_PUBLIC_FEATURE_BANCOS_BOLETOS=$NEXT_PUBLIC_FEATURE_BANCOS_BOLETOS
ENV NEXT_PUBLIC_FEATURE_BANCOS_CARTOES=$NEXT_PUBLIC_FEATURE_BANCOS_CARTOES
ENV NEXT_PUBLIC_FEATURE_BANCOS_PIX=$NEXT_PUBLIC_FEATURE_BANCOS_PIX
ENV NEXT_PUBLIC_FEATURE_BANCOS_TRIBUTOS=$NEXT_PUBLIC_FEATURE_BANCOS_TRIBUTOS
ENV NEXT_PUBLIC_FEATURE_BUSCA_EMPRESAS_POR_CPF=$NEXT_PUBLIC_FEATURE_BUSCA_EMPRESAS_POR_CPF
RUN npm install --include=dev
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000

# Usuário não-root
RUN addgroup --system --gid 1001 nodejs \
 && adduser  --system --uid 1001 nextjs

# Apenas o que é necessário em runtime
COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

USER nextjs
EXPOSE 3000
CMD ["node", "server.js"]
