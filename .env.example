# ╭──────────────────────────────────────────────╮
# │  Felipe Hub · variáveis de ambiente Docker  │
# ╰──────────────────────────────────────────────╯
#
# Copie este arquivo para .env e preencha:
#   cp .env.example .env
#
# Depois suba com: docker compose up

# ── LLMs (preencha pelo menos um) ─────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Cofre criptografado (obrigatório) ─────────
# Gere uma chave com:
#   docker run --rm python:3.12-slim sh -c "pip install -q cryptography && python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'"
# Cole a saída aqui:
ENCRYPTION_KEY=

# ── WhatsApp Evolution API (opcional) ─────────
# Para ativar: docker compose --profile wa up
EVOLUTION_API_KEY=trocar-em-producao-com-secret-forte
EVOLUTION_INSTANCE=felipe-hub
FELIPE_WHATSAPP_NUMBER=5541998765432

# ── Pluggy Open Finance (opcional) ────────────
# Sandbox grátis em https://dashboard.pluggy.ai
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_BASE_URL=https://api.pluggy.ai

# ── Telegram (opcional) ───────────────────────
TELEGRAM_BOT_TOKEN=

# ── Discord (opcional) ────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
