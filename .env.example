# ╭──────────────────────────────────────────────╮
# │  Felipe Hub · variáveis de ambiente Docker  │
# ╰──────────────────────────────────────────────╯
#
# Copie este arquivo para .env e preencha:
#   cp .env.example .env
#
# Depois suba com: docker compose up

# ── LLMs (preencha pelo menos um) ─────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Cofre criptografado (obrigatório) ─────────
# Gere uma chave com:
#   docker run --rm python:3.12-slim sh -c "pip install -q cryptography && python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'"
# Cole a saída aqui:
ENCRYPTION_KEY=

# ── WhatsApp Evolution API (opcional) ─────────
# Para ativar: docker compose --profile wa up
EVOLUTION_API_KEY=trocar-em-producao-com-secret-forte
EVOLUTION_INSTANCE=felipe-hub
FELIPE_WHATSAPP_NUMBER=5541998765432

# ── Pluggy Open Finance (opcional) ────────────
# Sandbox grátis em https://dashboard.pluggy.ai
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_BASE_URL=https://api.pluggy.ai

# ── Telegram (opcional) ───────────────────────
TELEGRAM_BOT_TOKEN=

# ── Discord (opcional) ────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ── CPF.CNPJ (busca empresas pelo CPF, pacote 15) ──
# Default = token público de TESTE (retorna dados fictícios).
# Pra produção, criar conta em https://www.cpfcnpj.com.br/register/
# e substituir o valor abaixo. Custo: R$ 0,23 por consulta.
CPF_LOOKUP_API_KEY=5ae973d7a997af13f0aaf2bf60e65803

# ── Sprint H · Autenticação multi-usuário ─────
# JWT_SECRET é OBRIGATÓRIO (login dá 500 sem ele). Gere uma vez com:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Não troque depois sem invalidar todas as sessões ativas.
JWT_SECRET=
# Bootstrap admin — usado UMA vez no primeiro startup com tabela users vazia.
# Depois de criado, esvazie pra evitar warnings.
BOOTSTRAP_ADMIN_EMAIL=felipe@exemplo.com.br
BOOTSTRAP_ADMIN_PASSWORD=trocar-no-primeiro-login
BOOTSTRAP_ADMIN_NAME=Felipe Bernardeli Palhares
# Cookie httpOnly em prod: deixe COOKIE_DOMAIN=.seu-dominio.com.br se você
# usa subdomínios separados (api.x e app.x). Em dev, deixe vazio.
COOKIE_DOMAIN=
